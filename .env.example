# Postgres connection string (Railway provides this automatically when
# you add a Postgres plugin and reference it as a variable)
DATABASE_URL="postgresql://user:password@host:5432/challenge_db"

# Open Wearables instance this service reads from
OPEN_WEARABLES_API_URL="https://your-open-wearables-instance.up.railway.app"
OPEN_WEARABLES_API_KEY="generate-this-in-the-open-wearables-dashboard"

# Shared secret you configure when registering the webhook subscription
# in Open Wearables — used to verify incoming webhook calls.
OPEN_WEARABLES_WEBHOOK_SECRET="choose-a-random-string"
